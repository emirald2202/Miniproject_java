# ─── Compiled Java class files ───────────────────────────────────────────────
*.class

# ─── Compiled output directory ───────────────────────────────────────────────
out/
bin/
build/

# ─── JavaFX native libraries (Windows) ───────────────────────────────────────
# ─── JavaFX native libraries (Linux) ──────────────────────────────────────────
# These are huge (~120MB+) runtime .so files — never commit them
lib_linux/

# ─── JavaFX native libraries (macOS) ─────────────────────────────────────────
# These are huge (~97MB+) runtime dylibs — never commit them
lib_mac/

# ─── Old/deprecated lib folder ───────────────────────────────────────────────
lib/


# ─── JAR files (runtime dependencies, not source) ────────────────────────────
*.jar

# ─── OS-generated junk ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE / Editor files ──────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.ipr
*.iws
*.project
*.classpath
.settings/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log

# ─── Claude Code files ───────────────────────────────────────────────────────
CLAUDE.md
.claude/
